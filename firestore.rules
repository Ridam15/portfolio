rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== Helper Functions ====================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin
    // ⚠️ IMPORTANT: Replace with your actual admin email(s)
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email in [
               'ridamchhapiya5@gmail.com',
               // Add more admin emails here:
               // 'another-admin@example.com',
             ];
    }
    
    // Validate timestamp fields
    function hasValidTimestamps() {
      return request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }
    
    // ==================== Portfolio Data ====================
    
    // Main portfolio content document
    match /portfolio_content/{document} {
      // Anyone can read portfolio data
      allow read: if true;
      
      // Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
    }
    
    // Portfolio sections (hero, about, contact)
    match /portfolio/{section} {
      // Anyone can read portfolio data
      allow read: if true;
      
      // Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
    }
    
    // ==================== Experiences ====================
    
    match /experiences/{experienceId} {
      // Anyone can read experiences
      allow read: if true;
      
      // Only admins can create experiences
      allow create: if isAdmin();
      
      // Only admins can update experiences
      allow update: if isAdmin();
      
      // Only admins can delete experiences
      allow delete: if isAdmin();
    }
    
    // ==================== Projects ====================
    
    match /projects/{projectId} {
      // Anyone can read projects
      allow read: if true;
      
      // Only admins can modify projects
      allow create, update, delete: if isAdmin();
    }
    
    // ==================== Skills ====================
    
    match /skill_categories/{categoryId} {
      // Anyone can read skill categories
      allow read: if true;
      
      // Only admins can modify skill categories
      allow create, update, delete: if isAdmin();
    }
    
    // ==================== Certifications ====================
    
    match /certifications/{certId} {
      // Anyone can read certifications
      allow read: if true;
      
      // Only admins can modify certifications
      allow create, update, delete: if isAdmin();
    }
    
    // ==================== Achievements ====================
    
    match /achievements/{achievementId} {
      // Anyone can read achievements
      allow read: if true;
      
      // Only admins can modify achievements
      allow create, update, delete: if isAdmin();
    }
    
    // ==================== Contact Submissions ====================
    
    match /contact_submissions/{submissionId} {
      // Only admins can read contact submissions
      allow read: if isAdmin();
      
      // Anyone can submit contact form
      allow create: if true;
      
      // Only admins can update/delete submissions
      allow update, delete: if isAdmin();
    }
    
    // ==================== User Profiles (Future Use) ====================
    
    match /users/{userId} {
      // Authenticated users can read any profile
      allow read: if isAuthenticated();
      
      // Users can only write to their own profile
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // ==================== Site Analytics (Future Use) ====================
    
    match /analytics/{docId} {
      // Only admins can read analytics
      allow read: if isAdmin();
      
      // Anyone can create (for tracking)
      allow create: if true;
      
      // Only admins can modify
      allow update, delete: if isAdmin();
    }
    
    // ==================== Default Deny ====================
    
    // Deny access to any other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

